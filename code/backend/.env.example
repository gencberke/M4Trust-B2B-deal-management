# M4Trust — AI extraction hattı ortam değişkenleri örneği.
# Bu dosyayı `code/.env` olarak kopyalayıp gerçek değerleri doldur.
# GERÇEK API ANAHTARINI ASLA COMMIT'LEME — .env gitignore'dadır.

# LLM sağlayıcı: "fake" (demo-güvenli, anahtar gerekmez) | "openai" (canlı çağrı)
LLM_PROVIDER=fake

# Canlı sağlayıcı ayarları (yalnızca LLM_PROVIDER=openai iken kullanılır)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-mini
LLM_API_KEY=
LLM_TIMEOUT=60

# RAG / Chroma — varsayılanlar korpusla uyumlu; normalde override gerekmez.
# CHROMA_DIR=
# RAG_MODEL=BAAI/bge-m3
# RAG_LEGAL_COLLECTION=legal_articles
# RAG_CONTRACT_COLLECTION=contract_examples
# RAG_SECURITY_COLLECTION=security_controls

# Ödeme sağlayıcı adapter seçimi (§3.3) — `moka_http` M1'de yalnız yan-panel client'ıdır.
PAYMENT_PROVIDER=mock

# Moka PaymentDealer contract-faithful HTTP client (PAYMENT_PROVIDER ana akışına henüz bağlı değil).
MOKA_CONTRACT_PROFILE=moka_payment_dealer_pool_v1
MOKA_BASE_URL=http://127.0.0.1:8001
MOKA_DEALER_CODE=DEALER-DEMO-001
MOKA_USERNAME=m4trust_demo
MOKA_PASSWORD=
MOKA_CARD_TOKEN=DEMO-TOKEN-SUCCESS
MOKA_SOFTWARE=M4Trust
MOKA_TIMEOUT_SECONDS=20

# Ayrı localhost mock Moka process'i — yukarıdaki client kimlikleriyle eşleşmelidir.
MOCK_MOKA_DEALER_CODE=DEALER-DEMO-001
MOCK_MOKA_USERNAME=m4trust_demo
MOCK_MOKA_PASSWORD=
MOCK_MOKA_VIRTUAL_POS_ENABLED=true
MOCK_MOKA_FAULTS_ENABLED=false
# MOCK_MOKA_DB_PATH=code/data/runtime/mock_moka.db

# Genel işlem listesi varsayılan olarak kapalıdır. Demo günü dashboard için açın.
DEMO_PUBLIC_DASHBOARD=false

# sqlite3 dosya yolu (§5) — varsayılan: code/data/runtime/m4trust.db
# DB_PATH=

# Validator NEEDS_REVIEW güven eşiği (§6.2)
VALIDATOR_CONFIDENCE_THRESHOLD=0.7

# Video analiz sağlayıcı: "fake" (demo-güvenli, anahtar gerekmez) | "roboflow" (canlı)
VIDEO_PROVIDER=fake

# Roboflow API anahtarı (yalnızca VIDEO_PROVIDER=roboflow iken kullanılır)
ROBOFLOW_API_KEY=

# İkincil (advisory) video sinyalinin dikkate alınacağı güven eşiği (§3.4).
# Altındaki analizler yalnızca warning üretir; sayım/hasar sinyali karar verdirmez.
VIDEO_ADVISORY_CONFIDENCE_THRESHOLD=0.80

# Identity/legal-entity şifreleme anahtarları (Faz 3A) — base64, 32 byte.
# Üretmek için: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# Insecure sabit fallback YOKTUR — boş bırakılırsa legal entity işlemleri
# KeyConfigurationError ile başarısız olur (fail-closed).
APP_ENCRYPTION_KEY=
APP_HMAC_KEY=

# Session cookie'sinde Secure bayrağı — yalnızca HTTPS altında prod'da true.
SESSION_COOKIE_SECURE=false

# Oturum süresi (saniye) — varsayılan 7 gün.
SESSION_TTL_SECONDS=604800

# Auth hardening. In-process rate limits are per worker; persistent lockout is DB-backed.
AUTH_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_WINDOW_SECONDS=900
ACCOUNT_LOCKOUT_SECONDS=900
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
EMAIL_VERIFICATION_REQUIRED=false
TRUST_PROXY_HEADERS=false
FRONTEND_BASE_URL=http://127.0.0.1:5173

# Bildirim adapter'ı: fake (ağa çıkmaz) veya smtp.
NOTIFICATION_PROVIDER=fake
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10

# Startup'ta stale processing job'ların recover edileceği yaş eşiği (saniye).
PROCESSING_JOB_STALE_SECONDS=300

# Legacy capability-token erişimi (party-view/manager-view/delivery, Faz 3C).
# Wave 3 hard cutover'a kadar true kalır; false = eski token akışları 403.
LEGACY_CAPABILITY_ACCESS_ENABLED=false

# LocalDocumentStorageProvider kökü (Plan 04 / Faz 4A, §2.11) — varsayılan:
# code/data/runtime/documents (code/data/runtime/ zaten gitignore'da).
# DOCUMENT_STORAGE_DIR=

# Multipart üst sınırları (byte). İstek belleğe alınmadan önce bounded okunur.
MAX_CONTRACT_UPLOAD_BYTES=26214400
MAX_EVIDENCE_UPLOAD_BYTES=26214400
