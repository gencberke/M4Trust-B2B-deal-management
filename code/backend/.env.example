# M4Trust — AI extraction hattı ortam değişkenleri örneği.
# Bu dosyayı `code/.env` olarak kopyalayıp gerçek değerleri doldur.
# GERÇEK API ANAHTARINI ASLA COMMIT'LEME — .env gitignore'dadır.

# LLM sağlayıcı: "fake" (demo-güvenli, anahtar gerekmez) | "openai" (canlı çağrı)
LLM_PROVIDER=fake

# Canlı sağlayıcı ayarları (yalnızca LLM_PROVIDER=openai iken kullanılır)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-mini
LLM_API_KEY=
LLM_TIMEOUT=60

# RAG / Chroma — varsayılanlar korpusla uyumlu; normalde override gerekmez.
# CHROMA_DIR=
# RAG_MODEL=BAAI/bge-m3
# RAG_LEGAL_COLLECTION=legal_articles
# RAG_CONTRACT_COLLECTION=contract_examples
# RAG_SECURITY_COLLECTION=security_controls

# Ödeme sağlayıcı adapter seçimi (§3.3) — `moka_http` M1'de yalnız yan-panel client'ıdır.
PAYMENT_PROVIDER=mock

# Moka PaymentDealer contract-faithful HTTP client (PAYMENT_PROVIDER ana akışına henüz bağlı değil).
MOKA_CONTRACT_PROFILE=moka_payment_dealer_pool_v1
MOKA_BASE_URL=http://127.0.0.1:8001
MOKA_DEALER_CODE=DEMO-DEALER
MOKA_USERNAME=demo-user
MOKA_PASSWORD=
MOKA_CARD_TOKEN=DEMO-TOKEN-SUCCESS
MOKA_SOFTWARE=M4Trust
MOKA_TIMEOUT_SECONDS=20

# Genel işlem listesi varsayılan olarak kapalıdır. Demo günü dashboard için açın.
DEMO_PUBLIC_DASHBOARD=true

# sqlite3 dosya yolu (§5) — varsayılan: code/data/runtime/m4trust.db
# DB_PATH=

# Validator NEEDS_REVIEW güven eşiği (§6.2)
VALIDATOR_CONFIDENCE_THRESHOLD=0.7

# Video analiz sağlayıcı: "fake" (demo-güvenli, anahtar gerekmez) | "roboflow" (canlı)
VIDEO_PROVIDER=fake

# Roboflow API anahtarı (yalnızca VIDEO_PROVIDER=roboflow iken kullanılır)
ROBOFLOW_API_KEY=

# İkincil (advisory) video sinyalinin dikkate alınacağı güven eşiği (§3.4).
# Altındaki analizler yalnızca warning üretir; sayım/hasar sinyali karar verdirmez.
VIDEO_ADVISORY_CONFIDENCE_THRESHOLD=0.80
